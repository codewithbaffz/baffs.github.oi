{
  "name": "FocusSession",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "task_title": {
      "type": "string"
    },
    "session_type": {
      "type": "string",
      "enum": ["pomodoro", "free"],
      "default": "pomodoro"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "ended_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_minutes": {
      "type": "number"
    },
    "completed": {
      "type": "boolean",
      "default": false
    },
    "cycles_completed": {
      "type": "number",
      "default": 0
    },
    "notes": {
      "type": "string"
    }
  },
  "required": ["user_id"],
  "rls": {
    "create": {
      "data.user_id": "{{user.id}}"
    },
    "read": {
      "data.user_id": "{{user.id}}"
    },
    "update": {
      "data.user_id": "{{user.id}}"
    },
    "delete": {
      "data.user_id": "{{user.id}}"
    }
  }
}
