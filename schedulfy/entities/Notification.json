{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "reminder_1day",
        "reminder_1hour",
        "overdue",
        "conflict",
        "mention",
        "assignment",
        "team_update",
        "ai_suggestion"
      ],
      "default": "reminder_1day"
    },
    "task_id": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "is_read": {
      "type": "boolean",
      "default": false
    },
    "action_url": {
      "type": "string"
    }
  },
  "required": ["user_id", "title", "message"],
  "rls": {
    "create": {
      "data.user_id": "{{user.id}}"
    },
    "read": {
      "data.user_id": "{{user.id}}"
    },
    "update": {
      "data.user_id": "{{user.id}}"
    },
    "delete": {
      "data.user_id": "{{user.id}}"
    }
  }
}
