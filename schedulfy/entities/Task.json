{
  "name": "Task",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["todo", "in_progress", "done", "overdue", "snoozed"],
      "default": "todo"
    },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high", "urgent"],
      "default": "medium"
    },
    "due_date": {
      "type": "string",
      "format": "date-time"
    },
    "start_date": {
      "type": "string",
      "format": "date-time"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "project_id": {
      "type": "string"
    },
    "assignee_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "template_id": {
      "type": "string"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string"
    },
    "is_ai_generated": {
      "type": "boolean",
      "default": false
    },
    "original_nlp_input": {
      "type": "string"
    },
    "reminder_1day_sent": {
      "type": "boolean",
      "default": false
    },
    "reminder_1hour_sent": {
      "type": "boolean",
      "default": false
    },
    "overdue_nudge_sent": {
      "type": "boolean",
      "default": false
    },
    "is_time_blocked": {
      "type": "boolean",
      "default": false
    },
    "calendar_event_id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": ["manual", "nlp", "email", "zoom", "lms", "template", "time_block"],
      "default": "manual"
    },
    "parent_task_id": {
      "type": "string"
    },
    "snooze_count": {
      "type": "number",
      "default": 0
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["title"],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "data.assignee_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "data.assignee_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}
