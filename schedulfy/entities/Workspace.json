{
  "name": "Workspace",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "admin_id": {
      "type": "string"
    },
    "invite_code": {
      "type": "string"
    },
    "member_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "logo_url": {
      "type": "string"
    },
    "color": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "admin_id"
  ],
  "rls": {
    "create": {
      "data.admin_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "data.admin_id": "{{user.id}}"
        },
        {
          "data.member_ids": {
            "$in": [
              "{{user.id}}"
            ]
          }
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.admin_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.admin_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}